# Solarized Dark theme for zsh-syntax-highlighting
# Palette: https://ethanschoonover.com/solarized/

ZSH_HIGHLIGHT_STYLES[default]='fg=244'                 # base0
ZSH_HIGHLIGHT_STYLES[unknown-token]='fg=160,bold'       # red
ZSH_HIGHLIGHT_STYLES[reserved-word]='fg=136'            # yellow
ZSH_HIGHLIGHT_STYLES[alias]='fg=64'                     # green
ZSH_HIGHLIGHT_STYLES[suffix-alias]='fg=64'              # green
ZSH_HIGHLIGHT_STYLES[global-alias]='fg=64'              # green
ZSH_HIGHLIGHT_STYLES[builtin]='fg=33'                   # blue
ZSH_HIGHLIGHT_STYLES[function]='fg=33'                  # blue
ZSH_HIGHLIGHT_STYLES[command]='fg=64'                   # green
ZSH_HIGHLIGHT_STYLES[precommand]='fg=64,underline'      # green
ZSH_HIGHLIGHT_STYLES[commandseparator]='fg=166'         # orange
ZSH_HIGHLIGHT_STYLES[hashed-command]='fg=64'            # green
ZSH_HIGHLIGHT_STYLES[autodirectory]='fg=166,underline'  # orange
ZSH_HIGHLIGHT_STYLES[path]='underline'
ZSH_HIGHLIGHT_STYLES[path_pathseparator]=''
ZSH_HIGHLIGHT_STYLES[globbing]='fg=125'                 # magenta
ZSH_HIGHLIGHT_STYLES[history-expansion]='fg=125'        # magenta
ZSH_HIGHLIGHT_STYLES[command-substitution]='fg=37'      # cyan
ZSH_HIGHLIGHT_STYLES[command-substitution-delimiter]='fg=37' # cyan
ZSH_HIGHLIGHT_STYLES[process-substitution]='fg=37'      # cyan
ZSH_HIGHLIGHT_STYLES[process-substitution-delimiter]='fg=37' # cyan
ZSH_HIGHLIGHT_STYLES[single-hyphen-option]='fg=244'     # base0
ZSH_HIGHLIGHT_STYLES[double-hyphen-option]='fg=244'     # base0
ZSH_HIGHLIGHT_STYLES[back-quoted-argument]='fg=37'      # cyan
ZSH_HIGHLIGHT_STYLES[back-quoted-argument-delimiter]='fg=37' # cyan
ZSH_HIGHLIGHT_STYLES[single-quoted-argument]='fg=37'    # cyan
ZSH_HIGHLIGHT_STYLES[double-quoted-argument]='fg=37'    # cyan
ZSH_HIGHLIGHT_STYLES[dollar-quoted-argument]='fg=37'    # cyan
ZSH_HIGHLIGHT_STYLES[dollar-double-quoted-argument]='fg=37' # cyan
ZSH_HIGHLIGHT_STYLES[back-double-quoted-argument]='fg=37'   # cyan
ZSH_HIGHLIGHT_STYLES[back-dollar-quoted-argument]='fg=37'   # cyan
ZSH_HIGHLIGHT_STYLES[assign]='fg=136'                   # yellow
ZSH_HIGHLIGHT_STYLES[redirection]='fg=166'              # orange
ZSH_HIGHLIGHT_STYLES[comment]='fg=240'                  # base01
ZSH_HIGHLIGHT_STYLES[named-fd]='fg=244'                 # base0
ZSH_HIGHLIGHT_STYLES[numeric-fd]='fg=244'               # base0
ZSH_HIGHLIGHT_STYLES[arg0]='fg=64'                      # green
